# --- Dependencies ---
# Ignores the node_modules folder in root, server, and client
node_modules/
*/node_modules/

# --- Environment Variables ---
# IMPORTANT: Never upload .env files to GitHub (keeps passwords/keys safe)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# --- Production Build ---
# Ignores the production build folder created by React
build/
dist/

# --- Logs ---
# Ignores log files
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs
*.log

# --- Testing ---
coverage/

# --- OS Specific Files ---
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# --- IDE / Editor Specific ---
# VS Code
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# --- Misc ---
# Ignores compressed files
*.zip
*.tar.gz
*.rar